# ============================================================
# DPNGAME Frontend - Variables de entorno
# Copia este archivo a: frontend-web/.env.local
# ============================================================

# URL del backend en produccion (Render)
# Para produccion apuntar al dominio personalizado:
VITE_API_URL=https://dpngame-backend.onrender.com

# En desarrollo local (si usas proxy de Vite, dejar vacio)
# VITE_API_URL=http://localhost:3000

# Nombre del entorno (informativo)
VITE_APP_ENV=production
